
fn main() -> () {
    let x = (0, test()) in
    let (_, z) = x in
    loop(z)
}

fn loop(x: int) -> () {
    match le(x, 10) {
        true => printnum(x); loop(add(x, 1)),
        false => ()
    }
}

fn stupid() -> int {
    match (1, 2, 3) {
        (x, y, mut z) => z := 42; z
    }
}

fn test() -> int {
    printnum(42);
    let mut x = stupid() in
    let mut y = 7 in
    swap(&x, &y);
    x
}

fn swap(x: *mut int, y: *mut int) -> () {
    let tmp = *x in
    *x := *y;
    *y := tmp
}

extern fn printnum(x: int) -> ();

extern fn add(x: int, y: int) -> int;

extern fn le(x: int, y: int) -> bool;