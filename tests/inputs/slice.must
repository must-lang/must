
fn main() -> int {
    let mut x = [6, 2, 4, 5, 9] in
    x[1] := 13;
    sort(&x, 0);
    printarr(&x, 0);
    x[2]
}

fn sort(arr: []mut int, id: int) -> () {
    match id <= 4 {
        false => (),
        true =>
            insert(arr, id);
            sort(arr, id + 1),
    }
}

fn printarr(arr: []int, id: int) -> () {
    match id <= 4 {
        false => (),
        true =>
            printnum(arr[id]);
            printarr(arr, id + 1),
    }
}

fn insert(mut arr: []mut int, j: int) -> () {
    match j <= 0 {
        true => (),
        false => match arr[j - 1] <= arr[j] {
            true => (),
            false =>
                swap(&arr[j - 1], &arr[j]);
                insert(arr, j - 1)
        }
    }
}

fn swap(x: *mut int, y: *mut int) -> () {
    let tmp = *x in
    *x := *y;
    *y := tmp
}

extern fn printnum(x: int) -> ();
